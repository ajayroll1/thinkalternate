    "actionConfiguration": {
      "body": "<div style=\"background:#000000; padding:50px 0; font-family: Arial, sans-serif;\">\n\n  <div style=\"max-width:520px; margin:auto; border-radius:14px; overflow:hidden; background:#ffffff; box-shadow:0 25px 60px rgba(0,0,0,0.4);\">\n\n    <!-- 🔴 TOP SECTION -->\n    <div style=\"\n      background:linear-gradient(135deg, #ff3b3b, #ff6a6a);\n      padding:40px 20px;\n      text-align:center;\n    \">\n\n      <!-- 📩 MESSAGE IMAGE -->\n      <img \n        src=\"https://cdn-icons-png.flaticon.com/512/561/561127.png\"\n        alt=\"message\"\n        style=\"width:80px; opacity:0.95;\"\n      />\n\n    </div>\n\n    <!-- ⚪ CONTENT -->\n    <div style=\"padding:30px 25px; text-align:center;\">\n\n      <h2 style=\"margin:0; font-size:22px; color:#111827; font-weight:700;\">\n        Ticket Updated Successfully\n      </h2>\n\n      <p style=\"margin:10px 0 20px; font-size:14px; color:#6b7280;\">\n        Your support request has been updated with the latest changes.\n      </p>\n\n      <!-- 📦 CARD -->\n      <div style=\"\n        background:#f9fafb;\n        border-radius:10px;\n        padding:20px;\n        text-align:left;\n      \">\n\n        <p style=\"margin:8px 0;\">\n          <b>Ticket ID:</b><br>\n          <span style=\"color:#111827;\">\n            {{this.params.ticketId || TicketsTable.updatedRow.TicketID || TicketsTable.triggeredRow.TicketID || TicketsTable.selectedRow.TicketID}}\n          </span>\n        </p>\n\n        <p style=\"margin:10px 0;\">\n          <b>Subject:</b><br>\n          <span style=\"color:#111827;\">\n            {{this.params.subject || TicketsTable.updatedRow.Subject || TicketsTable.triggeredRow.Subject || TicketsTable.selectedRow.Subject || \"Not provided\"}}\n          </span>\n        </p>\n\n        <!-- STATUS -->\n        <p style=\"margin:10px 0;\">\n          <b>Status:</b><br>\n          <span style=\"\n            display:inline-block;\n            padding:6px 14px;\n            border-radius:20px;\n            font-size:12px;\n            font-weight:600;\n            background:\n            {{\n              (this.params.status || TicketsTable.updatedRow.Status || TicketsTable.triggeredRow.Status || TicketsTable.selectedRow.Status) === 'Open' ? '#e0f2fe' :\n              (this.params.status || TicketsTable.updatedRow.Status || TicketsTable.triggeredRow.Status || TicketsTable.selectedRow.Status) === 'In Progress' ? '#fef3c7' :\n              '#dcfce7'\n            }};\n            color:\n            {{\n              (this.params.status || TicketsTable.updatedRow.Status || TicketsTable.triggeredRow.Status || TicketsTable.selectedRow.Status) === 'Open' ? '#0369a1' :\n              (this.params.status || TicketsTable.updatedRow.Status || TicketsTable.triggeredRow.Status || TicketsTable.selectedRow.Status) === 'In Progress' ? '#92400e' :\n              '#166534'\n            }};\n          \">\n            {{this.params.status || TicketsTable.updatedRow.Status || TicketsTable.triggeredRow.Status || TicketsTable.selectedRow.Status}}\n          </span>\n        </p>\n\n        <!-- PRIORITY -->\n        <p style=\"margin:10px 0;\">\n          <b>Priority:</b><br>\n          <span style=\"\n            display:inline-block;\n            padding:6px 14px;\n            border-radius:20px;\n            font-size:12px;\n            font-weight:600;\n            background:\n            {{\n              (this.params.priority || TicketsTable.updatedRow.Priority || TicketsTable.triggeredRow.Priority || TicketsTable.selectedRow.Priority) === 'High' ? '#fee2e2' :\n              (this.params.priority || TicketsTable.updatedRow.Priority || TicketsTable.triggeredRow.Priority || TicketsTable.selectedRow.Priority) === 'Medium' ? '#fef3c7' :\n              '#dcfce7'\n            }};\n            color:\n            {{\n              (this.params.priority || TicketsTable.updatedRow.Priority || TicketsTable.triggeredRow.Priority || TicketsTable.selectedRow.Priority) === 'High' ? '#991b1b' :\n              (this.params.priority || TicketsTable.updatedRow.Priority || TicketsTable.triggeredRow.Priority || TicketsTable.selectedRow.Priority) === 'Medium' ? '#92400e' :\n              '#166534'\n            }};\n          \">\n            {{this.params.priority || TicketsTable.updatedRow.Priority || TicketsTable.triggeredRow.Priority || TicketsTable.selectedRow.Priority || \"Not provided\"}}\n          </span>\n        </p>\n\n        <p style=\"margin:10px 0;\">\n          <b>Admin Notes:</b><br>\n          <span style=\"color:#374151;\">\n            {{this.params.adminNotes || TicketsTable.updatedRow.AdminNotes || TicketsTable.triggeredRow.AdminNotes || TicketsTable.selectedRow.AdminNotes || \"No notes added\"}}\n          </span>\n        </p>\n\n      </div>\n\n      <!-- FOOT -->\n      <p style=\"margin-top:20px; font-size:12px; color:#6b7280;\">\n        Updated At: {{this.params.updatedAt || moment().format(\"YYYY-MM-DD HH:mm:ss\")}}\n      </p>\n\n      <p style=\"margin-top:10px; font-size:13px; color:#6b7280;\">\n        If you need help, reply to this email with your ticket ID.\n      </p>\n\n    </div>\n\n  </div>\n\n  <!-- FOOTER -->\n  <div style=\"text-align:center; margin-top:20px; font-size:12px; color:#9ca3af;\">\n    © 2026 Support System • All rights reserved\n  </div>\n\n</div>",
      "encodeParamsToggle": true,
